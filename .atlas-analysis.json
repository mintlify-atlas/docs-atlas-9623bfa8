  "keyFeatures": [
    "Snowflake SQL dialect and wire protocol compatibility",
    "Apache Iceberg table format with ACID guarantees",
    "Single binary deployment with zero dependencies",
    "AWS Lambda and serverless support",
    "External catalog connectivity (S3 Tables, custom Iceberg)",
    "Horizontal scaling with query-per-node architecture",
    "Built on Apache DataFusion query engine",
    "Integration with dbt, BI tools, and Snowflake CLI"
  ],
  "publicApiSurface": [
    "embucketd binary with CLI flags",
    "--metastore-config (YAML configuration)",
    "--host / --port (server binding)",
    "--query-timeout-secs",
    "--max-concurrency-level",
    "--mem-pool-type / --mem-pool-size-mb",
    "--sql-parser-dialect",
    "Snowflake REST API endpoints (/api/v2/statements, /session, /queries)",
    "Iceberg REST Catalog API (/catalog)",
    "Health check endpoint (/health)",
    "OpenAPI spec (/openapi.json)",
    "Metastore YAML schema (volumes, databases, schemas, tables)",
    "Environment variables for configuration"
  ]
